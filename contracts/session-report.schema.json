{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gazetrack.local/contracts/session-report.schema.json",
  "title": "SessionReport",
  "type": "object",
  "required": ["session_id", "report_status", "generated_at", "metrics", "notes"],
  "properties": {
    "session_id": {
      "type": "string",
      "format": "uuid"
    },
    "study_id": {
      "type": ["string", "null"],
      "format": "uuid"
    },
    "report_status": {
      "type": "string",
      "enum": ["placeholder"]
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "metrics": {
      "type": "object"
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
