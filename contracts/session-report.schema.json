{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gazetrack.local/contracts/session-report.schema.json",
  "title": "SessionReport",
  "type": "object",
  "required": [
    "session_id",
    "analytics_version",
    "report_status",
    "generated_at",
    "event_count",
    "event_type_counts",
    "contains_gaze_events",
    "task_count",
    "aoi_count",
    "has_aoi_metrics",
    "aoi_metrics",
    "fixation_summary",
    "quality_summary",
    "replay_summary",
    "replay_events",
    "replay_fixations",
    "replay_aoi_overlay",
    "privacy_summary",
    "metrics",
    "notes"
  ],
  "properties": {
    "session_id": {
      "type": "string",
      "format": "uuid"
    },
    "study_id": {
      "type": ["string", "null"],
      "format": "uuid"
    },
    "study_name": {
      "type": ["string", "null"]
    },
    "study_objective": {
      "type": ["string", "null"]
    },
    "target_url": {
      "type": ["string", "null"]
    },
    "analytics_version": {
      "type": "string",
      "const": "fixation_demo_v1"
    },
    "report_status": {
      "type": "string",
      "enum": ["placeholder", "persisted"]
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "event_count": {
      "type": "integer",
      "minimum": 0
    },
    "event_type_counts": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    },
    "first_event_timestamp": {
      "type": ["string", "null"]
    },
    "last_event_timestamp": {
      "type": ["string", "null"]
    },
    "contains_gaze_events": {
      "type": "boolean"
    },
    "low_confidence_sample_rate": {
      "type": ["number", "null"],
      "minimum": 0,
      "maximum": 1
    },
    "session_quality_score": {
      "type": ["number", "null"],
      "minimum": 0,
      "maximum": 100
    },
    "task_count": {
      "type": "integer",
      "minimum": 0
    },
    "task_prompts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "aoi_count": {
      "type": "integer",
      "minimum": 0
    },
    "has_aoi_metrics": {
      "type": "boolean"
    },
    "aoi_metrics": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/aoi_metric"
      }
    },
    "completed": {
      "type": "boolean"
    },
    "insights": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "metrics": {
      "type": "object"
    },
    "privacy_summary": {
      "type": "object"
    },
    "fixation_summary": {
      "$ref": "#/$defs/fixation_summary"
    },
    "quality_summary": {
      "$ref": "#/$defs/quality_summary"
    },
    "replay_summary": {
      "$ref": "#/$defs/replay_summary"
    },
    "replay_events": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/replay_event"
      }
    },
    "replay_fixations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/replay_fixation"
      }
    },
    "replay_aoi_overlay": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/replay_aoi_overlay"
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "aoi_metric": {
      "type": "object",
      "required": [
        "aoi_id",
        "label",
        "coordinate_space",
        "gaze_sample_count",
        "approximate_dwell_ms",
        "click_count_inside_aoi",
        "fixation_count",
        "fixation_dwell_ms"
      ],
      "properties": {
        "aoi_id": {
          "type": "string",
          "format": "uuid"
        },
        "label": {
          "type": "string"
        },
        "page_url": {
          "type": ["string", "null"]
        },
        "coordinate_space": {
          "type": "string"
        },
        "gaze_sample_count": {
          "type": "integer",
          "minimum": 0
        },
        "first_gaze_timestamp": {
          "type": ["string", "null"]
        },
        "approximate_dwell_ms": {
          "type": "integer",
          "minimum": 0
        },
        "click_count_inside_aoi": {
          "type": "integer",
          "minimum": 0
        },
        "fixation_count": {
          "type": "integer",
          "minimum": 0
        },
        "fixation_dwell_ms": {
          "type": "integer",
          "minimum": 0
        },
        "first_fixation_timestamp": {
          "type": ["string", "null"]
        },
        "time_to_first_fixation_ms": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "average_fixation_confidence": {
          "type": ["number", "null"]
        }
      },
      "additionalProperties": false
    },
    "replay_summary": {
      "type": "object",
      "required": [
        "event_count",
        "gaze_event_count",
        "fixation_count",
        "click_count",
        "scroll_count",
        "task_event_count",
        "duration_ms",
        "coordinate_space"
      ],
      "properties": {
        "event_count": {
          "type": "integer",
          "minimum": 0
        },
        "gaze_event_count": {
          "type": "integer",
          "minimum": 0
        },
        "fixation_count": {
          "type": "integer",
          "minimum": 0
        },
        "click_count": {
          "type": "integer",
          "minimum": 0
        },
        "scroll_count": {
          "type": "integer",
          "minimum": 0
        },
        "task_event_count": {
          "type": "integer",
          "minimum": 0
        },
        "duration_ms": {
          "type": "integer",
          "minimum": 0
        },
        "coordinate_space": {
          "type": "string",
          "const": "normalized"
        }
      },
      "additionalProperties": false
    },
    "replay_event": {
      "type": "object",
      "required": ["id", "type", "timestamp", "relative_ms", "aoi_ids"],
      "properties": {
        "id": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "timestamp": {
          "type": "string"
        },
        "relative_ms": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "x": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 1
        },
        "y": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 1
        },
        "confidence": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 1
        },
        "aoi_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "uuid"
          }
        },
        "label": {
          "type": ["string", "null"]
        },
        "message": {
          "type": ["string", "null"]
        },
        "source": {
          "type": ["string", "null"]
        }
      },
      "additionalProperties": false
    },
    "replay_fixation": {
      "type": "object",
      "required": [
        "id",
        "type",
        "start_timestamp",
        "end_timestamp",
        "start_relative_ms",
        "end_relative_ms",
        "duration_ms",
        "x",
        "y",
        "sample_count",
        "aoi_ids"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "const": "fixation"
        },
        "start_timestamp": {
          "type": "string"
        },
        "end_timestamp": {
          "type": "string"
        },
        "start_relative_ms": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "end_relative_ms": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "duration_ms": {
          "type": "integer",
          "minimum": 0
        },
        "x": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "y": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "sample_count": {
          "type": "integer",
          "minimum": 0
        },
        "average_confidence": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 1
        },
        "aoi_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "additionalProperties": false
    },
    "replay_aoi_overlay": {
      "type": "object",
      "required": ["id", "label", "x", "y", "width", "height", "coordinate_space"],
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid"
        },
        "label": {
          "type": "string"
        },
        "x": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "y": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "width": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "height": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "coordinate_space": {
          "type": "string",
          "const": "normalized"
        }
      },
      "additionalProperties": false
    },
    "fixation_summary": {
      "type": "object",
      "required": [
        "fixation_count",
        "total_fixation_dwell_ms",
        "average_fixation_duration_ms",
        "fixation_algorithm",
        "fixation_algorithm_notes"
      ],
      "properties": {
        "fixation_count": {
          "type": "integer",
          "minimum": 0
        },
        "total_fixation_dwell_ms": {
          "type": "integer",
          "minimum": 0
        },
        "average_fixation_duration_ms": {
          "type": ["number", "null"]
        },
        "average_fixation_confidence": {
          "type": "number"
        },
        "fixation_algorithm": {
          "type": "string"
        },
        "fixation_algorithm_notes": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "quality_summary": {
      "type": "object",
      "required": [
        "score",
        "low_confidence_threshold",
        "low_confidence_sample_rate",
        "gaze_sample_count",
        "average_gaze_confidence",
        "calibration_event_count",
        "average_calibration_error_px",
        "quality_event_count",
        "sample_integrity_basis_event_count",
        "sample_completeness_score",
        "quality_verdict",
        "quality_reasons"
      ],
      "properties": {
        "score": {
          "type": ["number", "null"]
        },
        "low_confidence_threshold": {
          "type": "number"
        },
        "low_confidence_sample_rate": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 1
        },
        "gaze_sample_count": {
          "type": "integer",
          "minimum": 0
        },
        "average_gaze_confidence": {
          "type": ["number", "null"]
        },
        "calibration_event_count": {
          "type": "integer",
          "minimum": 0
        },
        "calibration_points_completed": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "average_calibration_error_px": {
          "type": ["number", "null"]
        },
        "average_calibration_error_normalized": {
          "type": ["number", "null"]
        },
        "quality_event_count": {
          "type": "integer",
          "minimum": 0
        },
        "sample_integrity_basis_event_count": {
          "type": "integer",
          "minimum": 0
        },
        "sample_completeness_score": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 1
        },
        "quality_verdict": {
          "type": "string",
          "enum": ["pass", "warn", "fail"]
        },
        "quality_reasons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    }
  }
}
